{
  "_comment": "Release verification policy for cilock binaries. Five layers of Rego stacked across the release-build step's predicates: github (source+ref), git (source integrity), commandrun (build hygiene + hermeticity), product (binary present), sbom (presence required). The policy itself is committed unsigned for reviewer transparency; the release workflow signs it (DSSE) and ships the signed copy as release-v1.policy.json with every release. Plain-text Rego sources are in deploy/cilock/release-rego-*.txt.",
  "expires": "2027-12-31T23:59:59Z",
  "name": "cilock-release-v1",
  "roots": {
    "sigstore-fulcio": {
      "_comment": "Public Sigstore Fulcio root, used to verify the keyless cosign signature on the binary tarball, .sig, and .cert that ship with every release.",
      "certConstraint": {
        "commonName": "https://fulcio.sigstore.dev"
      }
    }
  },
  "publickeys": {},
  "steps": {
    "release-build": {
      "name": "release-build",
      "_comment": "Built and signed in .github/workflows/release.yml. Identity is the GH Actions OIDC workflow identity, which Fulcio binds to the cosign cert. The cosign sign step in release.yml runs AFTER the verifier produces VSAs (this policy) — so a cosign signature on a published binary transitively proves the binary passed every Rego layer below.",
      "attestations": [
        {
          "type": "https://witness.dev/attestations/git/v0.1",
          "regopolicies": [
            {
              "name": "release-source-integrity",
              "_comment": "Decoded plain-text: deploy/cilock/release-rego-source-integrity.txt. Denies on dirty working tree or missing commit hash.",
              "module": ""
            }
          ]
        },
        {
          "type": "https://witness.dev/attestations/github/v0.1",
          "regopolicies": [
            {
              "name": "release-from-aflock-ai-rookery",
              "_comment": "Decoded: deny if input.repository != 'aflock-ai/rookery'; deny if input.reftype != 'tag'.",
              "module": ""
            }
          ]
        },
        {
          "type": "https://witness.dev/attestations/commandrun/v0.1",
          "regopolicies": [
            {
              "name": "release-build-hygiene",
              "_comment": "Decoded plain-text in deploy/cilock/release-rego-commandrun.txt. Denies on: missing -trimpath, missing cli.Version ldflags, CGO_ENABLED != 0.",
              "module": ""
            },
            {
              "name": "release-build-hermetic",
              "_comment": "Decoded plain-text in deploy/cilock/release-rego-hermetic.txt. Denies on network egress to any non-allowlisted host (uses --trace ptrace data: input.processes[].network.connections[].hostname from TLS SNI).",
              "module": ""
            }
          ]
        },
        {
          "type": "https://witness.dev/attestations/product/v0.1",
          "regopolicies": [
            {
              "name": "release-produced-cilock-binary",
              "_comment": "Decoded plain-text in deploy/cilock/release-rego-product.txt. Denies if the product set contains no file named 'cilock' or 'cilock.exe'.",
              "module": ""
            }
          ]
        },
        {
          "type": "https://witness.dev/attestations/sbom/v0.1",
          "regopolicies": [],
          "_comment": "SBOM presence is required — listing the type without a Rego asserts the attestation must exist in the envelope. cilock-action's 'sbom' attestor produces this from syft against the build's working directory."
        }
      ],
      "functionaries": [
        {
          "type": "root",
          "certConstraint": {
            "commonName": "https://fulcio.sigstore.dev",
            "extensions": {
              "buildConfigURI": "https://github.com/aflock-ai/rookery/.github/workflows/release.yml",
              "issuer": "https://token.actions.githubusercontent.com"
            }
          }
        }
      ]
    }
  }
}
