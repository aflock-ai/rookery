[72.815655, "o", "\u001b[2D\u001b[3B\r\u001b[4A  \u001b[1mThe gate\u001b[22m \u2014 the signed \u001b[38;5;153mci.policy.signed.json\u001b[39m evaluates \u001b[38;5;153mci-task\u001b[39m with the \u001b[38;5;153mno-leaked-secrets\u001b[39m Rego rule:\u001b[K\r\u001b[1B  \u001b[38;5;153mcount(input.findings) > 0 \u2192 deny\u001b[39m.\u001b[37GBoth\u001b[42Gsignatures\u001b[53Gverified\u001b[62G(policy\u001b[70G+\u001b[72Gattestation,\u001b[85Gkey\u001b[89G\u001b[38;5;153ma022c5294a45\u001b[39m),\u001b[104Gthen\u001b[109Gthe\r\u001b[1B  collection was rejected: \u001b[3m\"credential leak detected in CI step: 2 secret(s) found (github-pat).\"\u001b[23m \u001b[38;5;153mcilock verify\u001b[39m exited\r\u001b[2C\u001b[1B \u001b[1mnon-zero\u001b[22m \u2014 CI gates\u001b[24Ghere\u001b[29Gautomatically.\r\r\n\r\r\n\u001b[38;5;244m\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u001b[39m\r\r\n\u001b[38;5;246m\u276f\u00a0\u001b[39m\u001b[7m \u001b[27m\r\r\n\u001b[38;5;244m\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\