[1.5, "o", "\u001b[2D\u001b[3B\r\u001b[2C\u001b[3AStand up our internal supply\u001b[32Gchain\u001b[38Gfor\u001b[42GLiteLLM\u001b[50Gand\u001b[54Gwalk\u001b[59Gme\u001b[62Gthrough\u001b[70Git\u001b[73Gend\u001b[77Gto\u001b[80Gend\u001b[84G\u2014\u001b[86Git\u001b[89Gwas\u001b[93Gcompromised\u001b[105Gon\r\u001b[1B  PyPI so we build it ourselves. Narrate each step.\u001b[7m \u001b[27m\u001b[K\r\u001b[1B\u001b[38;5;244m\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u001b[39m\r\r\n\u001b[94G\u001b[38;5;246m\u25c9\u001b[96Gxhigh\u001b[102G\u00b7\u001b[104G/effort\u001b[39m\r\r\n\u001b[51C\u001b[3A"]
