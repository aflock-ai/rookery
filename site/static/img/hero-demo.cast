[49.45232, "o", "\u001b[2D\u001b[3B\r\u001b[7A\u001b[38;5;231m\u25cf\u001b[3G\u001b[39mThis is the human-authored policy. The key control\u001b[54Gis\u001b[57Gon\u001b[60Gthe\u001b[64G\u001b[38;5;153mbuild\u001b[70G\u001b[39mstep's\u001b[77Ggit\u001b[81Gattestation\u001b[93G\u2014\u001b[95Gthe\r\u001b[1B  \u001b[38;5;153mapproved-internal-fork\u001b[39m Rego rule. Decoded, it \u001b[38;5;153mdeny\u001b[39ms any release whose git remotes don't contain\r\u001b[2C\u001b[1B\u001b[38;5;153mgithub.com/BerriAI/litellm\u001b[39m,\u001b[31Gour\u001b[35Gapproved\u001b[44Ginternal\u001b[53Gfork.\u001b[59GThis\u001b[64Gis\u001b[67Gwhat\u001b[72Gstructurally\u001b[85Gprevents\u001b[94Gus\u001b[97Gfrom\u001b[102Gever\r\u001b[1B  shipping the compromised upstream PyPI artifact (1.82.7 / 1.82.8).\u001b[K\r\u001b[1B\u001b[K\r\u001b[2B\u001b[38;5;246m\u276f\u00a0\u001b[39m\u001b[7m \u001b[27m\u001b[K\r\r\n\u001b[38;5;244m\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u001b[39m\r\r\n\u001b[3G\u001b[38;5;246mesc\u001b[7Gto\u001b[10Ginterrupt\u001b[39m\r\r\n\u001b[2C\u001b[3A"]
