[56.518233, "o", "\u001b[2D\u001b[3B\r\u001b[7A\u001b[38;5;231m\u25cf\u001b[3G\u001b[39m\u001b[1mVerification succeeded.\u001b[22m The policy\u001b[38Gsignature\u001b[48Gchecked\u001b[56Gout\u001b[60Gagainst\u001b[68G\u001b[38;5;153mpolicy.pub\u001b[39m,\u001b[80Gall\u001b[84Gthree\u001b[90Gattestations\u001b[103G(source,\r\u001b[1B  build, scan) were signed by the approved key \u001b[38;5;153ma022c5294a45\u001b[39m, the \u001b[38;5;153mapproved-internal-fork\u001b[39m Rego\u001b[94Grule\u001b[99Gwas\u001b[103Gsatisfied,\r\u001b[3C\u001b[1Band\u001b[8Git\u001b[11Gall\u001b[15Gbinds\u001b[21Gto\u001b[24Gthe\u001b[28Gexact\u001b[34Gwheel\u001b[40Gdigest\u001b[47G\u001b[38;5;153msha256:1f3d\u2026f09d01\u001b[39m.\u001b[67GThe\u001b[71Grelease\u001b[79Gis\u001b[82Gprovably\u001b[91Gours.\r\u001b[1B\u001b[K\r\u001b[1B\u001b[38;5;244m\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\r\u001b[1B\u001b[38;5;246m\u276f\u00a0\u001b[39m\u001b[7m \u001b[27m\u001b[K\r\u001b[1B\u001b[38;5;244m\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500