[88.778227, "o", "\u001b[2D\u001b[3B\r\u001b[2C\u001b[5A-\u001b[5G\u001b[1mZero \u001b[38;5;153m.pth\u001b[39m files written on install\u001b[40G\u001b[22m\u2014\u001b[42Gthe\u001b[46Greport\u001b[53Gexplicitly\u001b[64Gtracks\u001b[71Gthis,\u001b[77Gsince\u001b[83Gthe\u001b[87G\u001b[38;5;153m.pth\u001b[92G\u001b[39mcredential\u001b[103Gstealer\u001b[111Gis\r\u001b[1B   precisely how 1.82.7 / 1.82.8 were compromised.\u001b[K\r\u001b[1B\u001b[K\r\u001b[2B\u001b[38;5;246m\u276f\u00a0\u001b[39m\u001b[7m \u001b[27m\u001b[K\r\r\n\u001b[38;5;244m\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u001b[39m\r\r\n\u001b[3G\u001b[38;5;246mesc\u001b[7Gto\u001b[10Ginterrupt\u001b[39m\r\r\n\u001b[2C\u001b[3A"]
[89.190989, "o", "\u001b[2D\u001b[3B\r\u001b[2C\u001b[5A-\u001b[5G\u001b[1mEven Trivy was watched.\u001b[29G\u001b[22mThe\u001b[33Gscan\u001b[38Gcaught\u001b[45Gour\u001b[49Gown\u001b[53Gscanner\u001b[61Gmaking\u001b[68GDNS\u001b[72G+\u001b[74Ga\u001b[76GTLS\u001b[80Gconnect\u001b[88G\u2014\u001b[90Gnothing\u001b[98Ggets\u001b[103Gan\r\u001b[1B  exemption from the kernel.\u001b[K\r\u001b[1B\u001b[K\r\u001b[2B\u001b[38;5;246m\u276f\u00a0\u001b[39m\u001b[7m \u001b[27m\u001b[K\r\r\n\u001b[38;5;244m\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u001b[39m\r\r\n\u001b[3G\u001b[38;5;246mesc\u001b[7Gto\u001b[10Ginterrupt\u001b[39m\r\r\n\u001b[2C\u001b[3A"]
