[73.801157, "o", "\u001b[2D\u001b[3B\r\u001b[2C\u001b[5A3.\u001b[6G\u001b[1mThe gate fired correctly.\u001b[32G\u001b[22m\u001b[38;5;153mcilock verify\u001b[46G\u001b[39mvalidated\u001b[56G\u001b[3mboth\u001b[61G\u001b[23msignatures\u001b[72G(policy\u001b[80Gvia\u001b[84G\u001b[38;5;153mpolicy.pub\u001b[39m,\u001b[96Gattestation\u001b[108Gvia\u001b[112Gour\r\u001b[1B  key), then the Rego rule \u001b[1mdenied the release\u001b[22m, naming both high-severity rules on host \u001b[38;5;153mcolima\u001b[39m. Exit\u00a01. This is a\u001b[K\r\u001b[1B  machine\u001b[11Gdecision\u001b[20Gdriven\u001b[27Gby\u001b[30Gsigned\u001b[37Ginput,\u001b[44Gnot\u001b[48Ga\u001b[50Greviewer's\u001b[61Gopinion.\r\u001b[1B\u001b[K\r\u001b[1B\u001b[38;5;244m\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u001b[39m\r\r\n\u001b[38;5;246m\u276f\u00a0\u001b[39m\u001b[7m \u001b[27m\r\r\n\u001b[38;5;244m\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\