[72.446737, "o", "\u001b[2D\u001b[3B\r\u001b[2C\u001b[5A2.\u001b[6G\u001b[1mThe real posture.\u001b[24G\u001b[22m220\u001b[28Gpass\u001b[33G/\u001b[35G113\u001b[39Gfail\u001b[44G/\u001b[46G68\u001b[49GN/A\u001b[53G/\u001b[55G7\u001b[57Gerror.\u001b[64GOf\u001b[67Gthe\u001b[71Gfailures:\u001b[81G\u001b[1m2 high\u001b[22m,\u001b[89G94\u001b[92Gmedium,\u001b[100G11\u001b[103Glow.\u001b[108GThe\u001b[112Gtwo\r\u001b[1B  high-severity ones are both empty-password rules \u2014 \u001b[38;5;153mno_empty_passwords_unix\u001b[39m and \u001b[38;5;153msshd_disable_empty_passwords\u001b[39m.\u001b[K\r\u001b[1B\u001b[K\r\u001b[2B\u001b[38;5;246m\u276f\u00a0\u001b[39m\u001b[7m \u001b[27m\u001b[K\r\r\n\u001b[38;5;244m\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u001b[39m\r\r\n\u001b[3G\u001b[38;5;246mesc\u001b[7Gto\u001b[10Ginterrupt\u001b[39m\r\r\n\u001b[2C\u001b[3A"]
