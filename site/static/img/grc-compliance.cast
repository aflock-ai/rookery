[79.027104, "o", "\u001b[2D\u001b[3B\r\u001b[4A  One honesty note on scope: the gate is keyed solely on \u001b[38;5;153mseverity == \"high\"\u001b[39m. The 94 medium failures (no nftables\u001b[K\r\u001b[1B  firewall,\u001b[13Gweak\u001b[18GSSH\u001b[22Gciphers,\u001b[31Gno\u001b[34GAIDE,\u001b[40Gno\u001b[43Gpwquality)\u001b[54Gdon't\u001b[60Gblock\u001b[66Gtoday\u001b[72G\u2014\u001b[74Gthat's\u001b[81Gthe\u001b[85Gpolicy's\u001b[94Gdeliberate\u001b[105Gbaseline,\u001b[115Gbut\r\u001b[1B  worth flagging to whoever owns the FedRAMP control set, since several of those map to controls an assessor will\u001b[K\r\u001b[2C\u001b[1Bstill ask about.\r\r\n\r\r\n\u001b[38;5;174m\u00b7\u001b[3GRazzle-dazz\u001b[38;5;216mlin\u001b[38;5;174mg\u2026\u001b[20G\u001b[38;5;246m(1m\u001b[24G16s\u001b[28G\u00b7\u001b[30G\u2193\u001b[32G3.5k\u001b[37Gtokens)\u001b[39m\r\r\n\u001b[38;5;246m \u001b[3G\u23bf\u001b[5G\u00a0Tip:\u001b[11GUse\u001b[15G/btw\u001b[20Gto\u001b[23Gask\u001b[27Ga\u001b[29Gquick\u001b[35Gside\u001b[40Gquestion\u001b[49Gwithout\u001b[57Ginterrupting\u001b[70GClaude's\u001b[79Gcurrent\u001b[87Gwork\u001b[39m\r\r\n\r\r\n\u001b[38;5;244m\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u001b[39m\r\r\n\u001b[38;5;246m\u276f\u00a0\u001b[39m\u001b[7m \u001b[27m\r\r\n\u001b[38;5;244m\u2500\u2500\u2500\u2500\u2500\u2500\u250