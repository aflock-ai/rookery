[71.523253, "o", "\u001b[2D\u001b[3B\r\u001b[4A  1. \u001b[1mSigned evidence, not a PDF.\u001b[22m The CIS Level 1 Server scan ran \u001b[3munder\u001b[23m \u001b[38;5;153mcilock-grc\u001b[39m (a rookery-built binary that\u001b[K\r\u001b[1B  includes\u001b[12Gthe\u001b[16G\u001b[38;5;153moscap\u001b[22G\u001b[39mattestor\u001b[31G\u2014\u001b[33Gconfirmed\u001b[43Gin\u001b[46G\u001b[38;5;153mattestors list\u001b[39m),\u001b[63Gso\u001b[66Gthe\u001b[70Gresult\u001b[77Gis\u001b[80Ga\u001b[82GDSSE\u001b[87Gattestation\u001b[99Gsigned\u001b[106Gby\u001b[109Gour\u001b[113Gkey\r\u001b[1B  (\u001b[38;5;153mkid=a022c529\u2026\u001b[39m), with the benchmark, host, and profile as named subjects.\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\r\n\u001b[38;5;244m\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u001b[39m\r\r\n\u001b[38;5;246m\u276f\u00a0\u001b[39m\u001b[7m \u001b[27m\r\r\n\u001b[38;5;244m\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500