[0.016, "o", "\u001b[2D\u001b[3B\r\u001b[6A\u001b[38;5;231m\u23fa\u001b[3G\u001b[39mThe policy verified\u001b[23Gthe curl scan\u001b[37Gagainst\u001b[45Gthe\u001b[49Gsubject\u001b[57Gdigest\u001b[64G\u2014\u001b[66Gthe\u001b[70Gvulnerability-scan\u001b[89Gevidence\u001b[98Gis\u001b[101Gsigned\r\u001b[2C\u001b[1Bby\u001b[6Gthe\u001b[10Gapproved\u001b[19Grelease\u001b[27Gkey\u001b[31Gand\u001b[35Gthe\u001b[39GRego\u001b[44Gsource-allowlist\u001b[61Gconfirmed\u001b[71Gthe\u001b[75Gbuild\u001b[81Gcame\u001b[86Gfrom\u001b[91Gthe\u001b[95G\u001b[38;5;153mcurl/curl\r\u001b[1B\u001b[39m  upstream. The \u001b[1mrelease is approved\u001b[22m (gate exit 0).\u001b[K\r\u001b[1B\u001b[K\r\u001b[1B\u001b[38;5;174m\u2733\u001b[39m \u001b[38;5;174mMeandering\u2026 \u001b[38;5;246m(7s \u00b7 \u2193\u001b[39m \u001b[38;5;246m335 tokens)\u001b[39m\u001b[K\r\u001b[2C\u001b[1B\u001b[K\r\r\n\u001b[38;5;244m\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u001b[39m\r\r\n\u001b[38;5;246m\u276f\u00a0\u001b[39m\u001b[7m \u001b[27m\r\r\n\u001b[38;5;244m\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500"]
