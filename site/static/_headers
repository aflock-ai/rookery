# Cloudflare Pages headers. static/ is copied verbatim into build/, so this lands
# at the site root. Mirrors testifysec.com's security + cache posture.

# Long-cache immutable build assets
/assets/*
  Cache-Control: public, max-age=31536000, immutable
/img/*
  Cache-Control: public, max-age=31536000, immutable

# Don't cache HTML (so the Factors snippet + capture always run on fresh markup)
/*.html
  Cache-Control: public, max-age=0, must-revalidate
/
  Cache-Control: public, max-age=0, must-revalidate

# Dashboard client assets — revalidate so a redeploy isn't served stale behind Access
/dash/app.js
  Cache-Control: no-cache
/dash/app.css
  Cache-Control: no-cache

# Security headers for all paths
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
