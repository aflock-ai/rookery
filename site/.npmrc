# Docusaurus 3.10's dep tree has a real peer-conflict between
# cssnano-preset-advanced (wants postcss-selector-parser@^6) and
# @csstools/selector-specificity (wants ^7). Older npm tolerates this;
# npm >= 10.9.7 (the version on current GitHub Actions ubuntu-latest)
# rejects it. legacy-peer-deps lets us install anyway.
#
# When Docusaurus or its CSS deps reconcile this conflict upstream,
# this file can be removed. Tracked here rather than only on CI so
# `npm install` and `npm ci` behave the same locally and in CI.
legacy-peer-deps=true
